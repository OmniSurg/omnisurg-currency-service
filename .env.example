# Runtime
OMNISURG_ENV=local
OMNISURG_HTTP_PORT=8092
OMNISURG_GRPC_PORT=9092
OMNISURG_LOG_LEVEL=debug

# Database
OMNISURG_DATABASE_URL=postgres://omnisurg_currency:omnisurg-local-only@localhost:5432/omnisurg_currency?sslmode=disable

# Auth (the JWT secret MUST match identity-service so tokens verify across services)
OMNISURG_JWT_SECRET=local-dev-secret-change-me

# Sentry (optional locally)
OMNISURG_SENTRY_DSN=

# CORS (comma separated)
OMNISURG_CORS_ORIGINS=http://localhost:5173,http://kawome.omnisurg.localhost

# Redis (latest rate cache, 60s ttl). The service degrades to the database if unreachable.
OMNISURG_REDIS_ADDR=localhost:6379
OMNISURG_REDIS_PASSWORD=omnisurg-local-only
OMNISURG_REDIS_DB=0
OMNISURG_RATE_CACHE_TTL_SECONDS=60

# ZimRate upstream (local stack uses the zimrate-stub). API key empty against the stub.
OMNISURG_ZIMRATE_URL=http://localhost:9003
OMNISURG_ZIMRATE_API_KEY=
